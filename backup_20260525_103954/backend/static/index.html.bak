<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>灵山胜境 · AI导游小灵</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:"Microsoft YaHei",sans-serif;background:linear-gradient(180deg,#1a0533,#0d1b3e);height:100vh;display:flex;justify-content:center;align-items:center;overflow:hidden}
        .stars{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
        .star{position:absolute;background:white;border-radius:50%;animation:twinkle 2s infinite alternate}
        @keyframes twinkle{from{opacity:.3}to{opacity:1}}
        .start-screen{position:fixed;top:0;left:0;width:100%;height:100%;background:linear-gradient(135deg,#1a0533,#2d1b4e);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;color:white;text-align:center}
        .start-screen h1{font-size:2.5em;margin-bottom:10px;font-weight:300}
        .model-grid{display:flex;gap:25px;flex-wrap:wrap;justify-content:center;margin-bottom:30px}
        .model-card{background:rgba(255,255,255,0.1);border-radius:20px;padding:25px;width:160px;cursor:pointer;transition:0.3s;border:2px solid transparent}
        .model-card:hover{background:rgba(255,255,255,0.2);border-color:#FFD700}
        .model-card .icon{font-size:60px;line-height:1}
        .model-card .name{font-size:14px;font-weight:bold;margin-top:10px}
        .start-buttons button{background:rgba(255,255,255,0.2);border:1px solid white;color:white;padding:12px 30px;border-radius:10px;cursor:pointer;font-size:16px;margin:0 10px}
        .app{width:1000px;height:680px;display:none;background:rgba(255,255,255,.96);border-radius:20px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5);z-index:1}
        .human-panel{width:400px;background:linear-gradient(180deg,#667eea,#764ba2);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative}
        .avatar-area{position:relative;z-index:2;text-align:center;width:300px;height:400px;overflow:hidden;background:transparent}
        /* iframe 样式，确保填满容器 */
        #avatarIframe { width: 300px; height: 400px; border: none; background: transparent; display: none; }
        .name-display{color:white;font-size:20px;font-weight:bold;margin-top:10px}
        .switch-bar{position:absolute;bottom:80px;display:flex;gap:10px}
        .switch-bar button{background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.3);color:white;padding:6px 15px;border-radius:12px;cursor:pointer;font-size:12px}
        .chat-panel{flex:1;display:flex;flex-direction:column;background:#fafbfc}
        .chat-header{position:relative;padding:16px;text-align:center;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:17px;font-weight:bold}
        .btn-clear{position:absolute;right:12px;top:14px;background:rgba(255,255,255,.2);border:none;color:white;padding:4px 12px;border-radius:10px;cursor:pointer;font-size:11px}
        .trending-bar{padding:8px 12px;background:#f0f4ff;border-bottom:1px solid #d0d5fa;overflow-x:auto;white-space:nowrap;display:flex;align-items:center;gap:8px}
        .trending-item{display:inline-block;background:#eef2ff;color:#333;font-size:12px;padding:4px 12px;border-radius:14px;cursor:pointer;border:1px solid #d0d5fa;flex-shrink:0}
        .messages{flex:1;overflow-y:auto;padding:15px;display:flex;flex-direction:column;gap:8px;background:#f5f7fa}
        .msg{max-width:80%;padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.5}
        .msg.user{align-self:flex-end;background:linear-gradient(135deg,#667eea,#764ba2);color:white}
        .msg.bot{align-self:flex-start;background:white;color:#333;border:1px solid#e8e8e8}
        .input-area{display:flex;gap:10px;padding:12px 15px;background:white;border-top:1px solid#eee;align-items:center}
        .input-area input{flex:1;padding:11px 16px;border-radius:22px;border:1.5px solid#e0e0e0;font-size:14px;outline:none;background:#f8f9fb}
        .btn-voice{width:42px;height:42px;border-radius:50%;border:none;cursor:pointer;background:#f0f0f5;display:flex;align-items:center;justify-content:center}
        .btn-voice.recording{background:#ff4757}
        .btn-send{width:42px;height:42px;border-radius:50%;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:18px;cursor:pointer;font-weight:bold;display:flex;align-items:center;justify-content:center}
        .voice-text{font-size:11px;color:#999;padding:2px 15px;text-align:center;min-height:16px}
        #feedbackBar{display:none;padding:8px 15px;background:#f0f4ff;border-top:1px solid #d0d5fa;text-align:center;font-size:14px}
    </style>
</head>
<body>
<div class="stars" id="stars"></div>

<!-- 启动界面 -->
<div class="start-screen" id="startScreen">
    <h1>灵山胜境</h1>
    <div class="model-grid">
        <div class="model-card" onclick="useDefault()">
            <div class="icon">🧑</div><div class="name">默认导游小灵</div>
        </div>
        <div class="model-card" onclick="switchToLive2D();showMainApp()">
            <div class="icon">🎀</div><div class="name">Shizuku (Live2D)</div>
        </div>
    </div>
    <div class="start-buttons">
        <button onclick="quickStart()">快速进入</button>
        <button onclick="useDefault()">使用默认形象</button>
    </div>
</div>

<!-- 主界面 -->
<div class="app" id="mainApp">
    <div class="human-panel">
        <div class="avatar-area" id="avatarContainer">
            <!-- 默认 SVG -->
            <div id="defaultAvatar" style="display:flex;flex-direction:column;align-items:center;">
                <svg width="200" height="250" viewBox="0 0 220 320">
                    <circle cx="110" cy="120" r="80" fill="#667eea"/>
                    <text x="110" y="220" text-anchor="middle" fill="white" font-size="14">导游·小灵</text>
                </svg>
                <div class="name-display"><span style="color:#00ff88">●</span> 小灵<div class="role" style="font-size:11px;opacity:.8">AI 智慧导游</div></div>
            </div>
            <!-- Live2D iframe -->
            <iframe id="avatarIframe" src="/static/avatar.html"></iframe>
        </div>
        <div class="switch-bar">
            <button onclick="switchToDefault()">默认形象</button>
            <button onclick="switchToLive2D()">Shizuku</button>
        </div>
    </div>
    <div class="chat-panel">
        <div class="chat-header">灵 山 胜 境<div class="sub" style="font-size:10px;opacity:.8">—— 千年佛国 · 智慧之旅 ——</div><button class="btn-clear" onclick="clearChat()">新对话</button></div>
        <div class="trending-bar" id="trendingBar"><span style="font-size:12px;color:#667eea;font-weight:bold">热门问题</span></div>
        <div class="messages" id="messages"><div class="msg bot">嗨！我是小灵，你的专属AI导游~<br>灵山胜境的故事，让我讲给你听！</div></div>
        <div class="voice-text" id="voiceText"></div>
        <div class="input-area">
            <input type="text" id="userInput" placeholder="问我任何问题，或按住麦克风说话" onkeypress="if(event.key=='Enter')sendText()">
            <button class="btn-voice" id="voiceBtn" title="按住说话">
                <svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
            </button>
            <button class="btn-send" onclick="sendText()" title="发送">
                <svg viewBox="0 0 24 24" width="20" height="20"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
            </button>
        </div>
    </div>
</div>

<script>
// 背景星星
for(let i=0;i<60;i++){const s=document.createElement('div');s.className='star';s.style.left=Math.random()*100+'%';s.style.top=Math.random()*100+'%';s.style.width=s.style.height=(1+Math.random()*3)+'px';s.style.animationDelay=Math.random()*2+'s';document.body.appendChild(s)}

let currentAvatarType = 'svg';
let currentAudio = null;

// 启动界面
function showMainApp(){document.getElementById('startScreen').style.display='none';document.getElementById('mainApp').style.display='flex'}
function useDefault(){switchToDefault();showMainApp()}
function quickStart(){showMainApp()}

// 形象切换
function switchToDefault(){
    document.getElementById('defaultAvatar').style.display='flex';
    document.getElementById('avatarIframe').style.display='none';
    // 停止 iframe 中的口型
    try {
        document.getElementById('avatarIframe').contentWindow.stopMouthSync();
    } catch(e) {}
    currentAvatarType='svg';
}
function switchToLive2D(){
    document.getElementById('defaultAvatar').style.display='none';
    document.getElementById('avatarIframe').style.display='block';
    currentAvatarType='live2d';
}

// 口型驱动（通过 iframe 调用内部函数）
function startMouthSync() {
    try {
        const iframe = document.getElementById('avatarIframe');
        iframe.contentWindow.startMouthSync();
    } catch(e) {}
}
function stopMouthSync() {
    try {
        const iframe = document.getElementById('avatarIframe');
        iframe.contentWindow.stopMouthSync();
    } catch(e) {}
}

// 聊天核心
function addMsg(t,u){const d=document.createElement('div');d.className='msg '+(u?'user':'bot');d.textContent=t;document.getElementById('messages').appendChild(d);document.getElementById('messages').scrollTop=document.getElementById('messages').scrollHeight}
async function sendText(){
  const i=document.getElementById('userInput'),b=document.querySelector('.btn-send');
  const t=i.value.trim();if(!t)return;
  addMsg(t,true);i.value='';
  try{
    const r=await fetch('/api/chat/tts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:t})});
    const d=await r.json();
    addMsg(d.answer,false);
    if(d.audio_url){
      document.getElementById('voiceText').textContent='播放中...';
      stopAll();const a=new Audio(d.audio_url);currentAudio=a;
      a.onplay = function(){ startMouthSync(); };
      a.onended = function(){ stopMouthSync(); document.getElementById('voiceText').textContent=''; currentAudio=null; };
      a.onpause = function(){ stopMouthSync(); };
      a.play();
    }
  }catch(e){addMsg('网络波动，请稍后重试',false)}
  i.focus();
}
function stopAll(){if(currentAudio){currentAudio.pause();currentAudio=null};stopMouthSync();document.getElementById('voiceText').textContent=''}
async function clearChat(){stopAll();try{await fetch('/api/chat/clear',{method:'POST'})}catch(e){};document.getElementById('messages').innerHTML='<div class="msg bot">对话已重置~<br>我是小灵，有什么想问的？</div>'}
document.addEventListener('keydown',function(e){if(currentAudio){e.preventDefault();stopAll();document.getElementById('voiceText').textContent='已停止朗读'}});

// 语音输入
let mr,chunks=[],recording=false;
async function startRec(){
  try{
    const s=await navigator.mediaDevices.getUserMedia({audio:true});
    mr=new MediaRecorder(s,{mimeType:'audio/webm'});chunks=[];
    mr.ondataavailable=e=>chunks.push(e.data);
    mr.onstop=async()=>{
      s.getTracks().forEach(t=>t.stop());
      const f=new FormData();f.append('file',new Blob(chunks,{type:'audio/webm'}),'r.webm');
      try{
        const r=await fetch('/api/chat/voice',{method:'POST',body:f});
        const d=await r.json();
        addMsg(d.reply_text,false);
        if(d.audio_url){
          stopAll();const a=new Audio(d.audio_url);currentAudio=a;
          a.onplay = function(){ startMouthSync(); };
          a.onended = function(){ stopMouthSync(); currentAudio=null; };
          a.onpause = function(){ stopMouthSync(); };
          a.play();
        }
      }catch(e){stopSpeak()}
    };
    mr.start();recording=true;
    document.getElementById('voiceBtn').classList.add('recording');
  }catch(e){}
}
function stopRec(){if(mr&&recording){mr.stop();recording=false}document.getElementById('voiceBtn').classList.remove('recording')}
document.getElementById('voiceBtn').addEventListener('mousedown',startRec);
document.getElementById('voiceBtn').addEventListener('mouseup',stopRec);

// 反馈
async function sendFeedback(rating){try{await fetch('/api/feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({rating})});}catch(e){};document.getElementById('feedbackBar').style.display='none';}

// 热门问题
async function loadTrending(){
  try{
    const res=await fetch('/api/admin/dashboard');
    const data=await res.json();
    const bar=document.getElementById('trendingBar');
    bar.querySelectorAll('.trending-item').forEach(el=>el.remove());
    if(data.top_questions) data.top_questions.forEach(item=>{
      const tag=document.createElement('span');
      tag.className='trending-item';tag.textContent=item.q;
      tag.onclick=()=>{document.getElementById('userInput').value=item.q;sendText()};
      bar.appendChild(tag);
    });
  }catch(e){}
}
loadTrending();setInterval(loadTrending,30000);

// 初始化
document.getElementById('startScreen').style.display='flex';
document.getElementById('mainApp').style.display='none';
</script>
</body>
</html>
