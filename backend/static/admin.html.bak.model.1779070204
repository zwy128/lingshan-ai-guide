<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理后台 | 灵山胜境AI导游</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:"Microsoft YaHei",sans-serif;background:#0a0e17;color:#c0c8d8;min-height:100vh;display:flex}
        .sidebar{width:220px;background:#111827;border-right:1px solid #1f2937;padding:20px 0;min-height:100vh}
        .sidebar .logo{text-align:center;padding:20px;font-size:20px;font-weight:bold;background:linear-gradient(135deg,#f5af19,#f12711);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        .nav-item{padding:14px 24px;cursor:pointer;color:#9ca3af;border-left:3px solid transparent;transition:.3s;display:flex;align-items:center;gap:10px}
        .nav-item:hover,.nav-item.active{background:rgba(255,215,0,.05);color:#FFD700;border-left-color:#FFD700}
        .main{flex:1;padding:30px;overflow-y:auto;max-height:100vh}
        .page-title{font-size:24px;font-weight:bold;margin-bottom:24px;color:#fff}
        .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:30px}
        .stat-card{background:linear-gradient(135deg,#1a1f2e,#1f2937);border-radius:16px;padding:24px;border:1px solid #2a3347}
        .stat-card .label{font-size:13px;color:#9ca3af;margin-bottom:8px}
        .stat-card .value{font-size:36px;font-weight:bold;color:#FFD700}
        .chart-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
        .chart-card{background:#111827;border-radius:16px;padding:24px;border:1px solid #1f2937}
        .chart-card h3{font-size:16px;color:#e5e7eb;margin-bottom:16px}
        .hot-item{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #1f2937}
        .hot-item .rank{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:bold;background:#1f2937;color:#9ca3af}
        .hot-item .rank.top1{background:#FFD700;color:#1a1a2e}
        .hot-item .rank.top2{background:#c0c0c0;color:#1a1a2e}
        .hot-item .rank.top3{background:#cd7f32;color:#1a1a2e}
        .hot-item .q-text{flex:1;margin-left:12px;font-size:14px}
        .hot-item .q-count{color:#FFD700;font-weight:bold}
        .page{display:none}.page.active{display:block}
        button.btn{background:#1f2937;color:#fff;border:1px solid #2a3347;padding:6px 14px;border-radius:8px;cursor:pointer;font-size:13px;transition:.2s}
        button.btn:hover{background:#374151;border-color:#FFD700}
        .bar-chart{display:flex;align-items:flex-end;gap:6px;height:120px;margin-top:10px}
        .bar{flex:1;background:linear-gradient(180deg,#667eea,#764ba2);border-radius:4px 4px 0 0;min-height:4px;position:relative;text-align:center}
        .bar span{position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:11px;color:#FFD700}
        .bar .label{position:absolute;bottom:-22px;left:50%;transform:translateX(-50%);font-size:10px;color:#9ca3af}
        table{width:100%;border-collapse:collapse;font-size:13px}
        th,td{text-align:left;padding:8px 12px;border-bottom:1px solid #1f2937}
        th{color:#FFD700;font-weight:normal}
        input[type=file]{color:#c0c8d8;margin-top:10px}
    </style>
</head>
<body>
<div class="sidebar">
    <div class="logo">灵山管理台</div>
    <div class="nav-item active" onclick="showPage('dashboard')">数据大屏</div>
    <div class="nav-item" onclick="showPage('history')">交互历史</div>
    <div class="nav-item" onclick="showPage('feedbacks')">用户反馈</div>
    <div class="nav-item" onclick="showPage('knowledge')">知识库管理</div>
    <div class="nav-item" onclick="window.open('/')">游客端</div>
</div>
<div class="main">
    <!-- 数据大屏页 -->
    <div class="page active" id="page-dashboard">
        <div class="page-title">运营数据大屏</div>
        <div class="stats-grid">
            <div class="stat-card"><div class="label">今日服务人次</div><div class="value" id="todayVisitors">-</div></div>
            <div class="stat-card"><div class="label">本周累计问答</div><div class="value" id="weekVisitors">-</div></div>
            <div class="stat-card"><div class="label">游客满意度</div><div class="value" id="satisfaction">-</div></div>
            <div class="stat-card"><div class="label">平均响应时间</div><div class="value" id="avgResponse">-</div></div>
        </div>
        <div class="chart-row">
            <div class="chart-card">
                <h3>热门问题 Top 5</h3>
                <div id="topQuestions"></div>
            </div>
            <div class="chart-card">
                <h3>近7天服务量</h3>
                <div id="dailyChart" class="bar-chart"></div>
            </div>
        </div>
        <div style="margin-top:15px;">
            <button class="btn" onclick="exportData('json')">导出JSON</button>
            <button class="btn" onclick="exportData('csv')">导出CSV</button>
        </div>
    </div>

    <!-- 交互历史页 -->
    <div class="page" id="page-history">
        <div class="page-title">最近交互记录</div>
        <div id="historyList" class="chart-card" style="max-height:500px;overflow-y:auto;"></div>
    </div>

    <!-- 用户反馈页 -->
    <div class="page" id="page-feedbacks">
        <div class="page-title">用户反馈</div>
        <div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px;">
            <div class="stat-card"><div class="label">满意</div><div class="value" style="color:#4caf50" id="goodCount">0</div></div>
            <div class="stat-card"><div class="label">一般</div><div class="value" style="color:#ff9800" id="neutralCount">0</div></div>
            <div class="stat-card"><div class="label">不满意</div><div class="value" style="color:#f44336" id="badCount">0</div></div>
        </div>
        <div id="feedbackList" class="chart-card" style="max-height:400px;overflow-y:auto;"></div>
    </div>

    <!-- 知识库管理页 -->
    <div class="page" id="page-knowledge">
        <div class="page-title">知识库文档管理</div>
        <div style="margin-bottom:20px;">
            <input type="file" id="docFile" accept=".txt,.docx,.pdf">
            <button class="btn" onclick="uploadDocument()">上传新文档</button><button class="btn" onclick="rebuildIndex()" style="margin-left:10px;">重建索引</button>
            <span id="uploadStatus" style="color:#FFD700;margin-left:10px;"></span>
        </div>
        <div class="chart-card">
            <h3>现有文档</h3>
            <div id="docList"></div>
        </div>
    </div>
</div>

<script>
// 页面切换
function showPage(name){
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('page-'+name).classList.add('active');
    event.target.closest('.nav-item').classList.add('active');
    if(name === 'dashboard') loadDashboard();
    if(name === 'history') loadHistory();
    if(name === 'feedbacks') loadFeedbacks();
    if(name === 'knowledge') loadDocuments();
}

// 数据大屏
async function loadDashboard(){
    const res = await fetch('/api/admin/dashboard');
    const data = await res.json();
    document.getElementById('todayVisitors').textContent = data.today_visitors || 0;
    document.getElementById('weekVisitors').textContent = data.week_visitors || 0;
    document.getElementById('satisfaction').textContent = data.satisfaction_rate ? data.satisfaction_rate+'%' : '-';
    document.getElementById('avgResponse').textContent = (data.avg_response_time||0)+'s';
    const topDiv = document.getElementById('topQuestions');
    topDiv.innerHTML = '';
    (data.top_questions || []).forEach((item, idx) => {
        const rankClass = idx===0?'top1':idx===1?'top2':idx===2?'top3':'';
        topDiv.innerHTML += `<div class="hot-item"><span class="rank ${rankClass}">${idx+1}</span><span class="q-text">${item.q}</span><span class="q-count">${item.count}次</span></div>`;
    });
    // 近7天服务量
    const dailyRes = await fetch('/api/admin/stats/daily');
    const dailyData = await dailyRes.json();
    const maxCount = Math.max(...dailyData.map(d=>d.count), 1);
    const chartDiv = document.getElementById('dailyChart');
    chartDiv.innerHTML = dailyData.map(d => {
        const height = (d.count / maxCount * 100) + '%';
        return `<div class="bar" style="height:${height}"><span>${d.count}</span><div class="label">${d.date.slice(5)}</div></div>`;
    }).join('');
}
// 导出数据
async function exportData(format){
    const a = document.createElement('a');
    a.href = `/api/admin/export?format=${format}`;
    a.download = `interaction_log.${format}`;
    a.click();
}
// 交互历史
async function loadHistory(){
    const res = await fetch('/api/admin/recent');
    const data = await res.json();
    document.getElementById('historyList').innerHTML = data.map(log => `
        <div style="padding:10px;border-bottom:1px solid #1f2937;">
            <div style="color:#FFD700;font-size:12px;">${log.date} ${new Date(log.timestamp*1000).toLocaleTimeString()}</div>
            <div style="font-weight:bold;margin-top:4px;">Q: ${log.question}</div>
            <div style="color:#9ca3af;font-size:13px;">A: ${log.answer}</div>
        </div>
    `).join('');
}
// 用户反馈
async function loadFeedbacks(){
    const res = await fetch('/api/admin/feedbacks');
    const feedbacks = await res.json();
    const good = feedbacks.filter(f=>f.rating==='good').length;
    const neutral = feedbacks.filter(f=>f.rating==='neutral').length;
    const bad = feedbacks.filter(f=>f.rating==='bad').length;
    document.getElementById('goodCount').textContent = good;
    document.getElementById('neutralCount').textContent = neutral;
    document.getElementById('badCount').textContent = bad;
    const listDiv = document.getElementById('feedbackList');
    listDiv.innerHTML = feedbacks.slice().reverse().map(f => `
        <div style="padding:8px;border-bottom:1px solid #1f2937;display:flex;justify-content:space-between;">
            <span>${f.date} ${new Date(f.timestamp*1000).toLocaleTimeString()}</span>
            <span style="color:${f.rating==='good'?'#4caf50':f.rating==='bad'?'#f44336':'#ff9800'}">${f.rating}</span>
        </div>
    `).join('');
}
// 知识库管理
async function loadDocuments(){
    const res = await fetch('/api/admin/documents');
    const docs = await res.json();
    document.getElementById('docList').innerHTML = docs.map(d => `<div style="padding:6px 0;border-bottom:1px solid #1f2937;">📄 ${d.name}</div>`).join('');
}
async function uploadDocument(){
    const file = document.getElementById('docFile').files[0];
    if(!file) return;
    const form = new FormData();
    form.append('file', file);
    const res = await fetch('/api/admin/upload-document', {method:'POST', body:form});
    const data = await res.json();
    document.getElementById('uploadStatus').textContent = data.status === 'ok' ? '上传成功' : '上传失败';
    loadDocuments();
}

// 初始加载
loadDashboard();
setInterval(loadDashboard, 10000);

async function rebuildIndex(){
    if(!confirm('重建索引将使新上传的文档生效，确定继续吗？')) return;
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = '重建中...';
    try {
        const res = await fetch('/api/admin/rebuild-index', {method:'POST'});
        const data = await res.json();
        alert(data.status === 'ok' ? '索引重建成功！' : '重建失败：'+data.message);
    } catch(e) {
        alert('网络错误');
    }
    btn.disabled = false;
    btn.textContent = '重建索引';
}

</script>
</body>
</html>
