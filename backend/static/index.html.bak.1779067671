<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>灵山胜境 · AI导游小灵</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Microsoft YaHei",sans-serif;background:linear-gradient(180deg,#1a0533,#0d1b3e);height:100vh;display:flex;justify-content:center;align-items:center;overflow:hidden}
.stars{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
.star{position:absolute;background:white;border-radius:50%;animation:twinkle 2s infinite alternate}
@keyframes twinkle{from{opacity:.3}to{opacity:1}}
.app{width:1000px;height:680px;display:flex;background:rgba(255,255,255,.96);border-radius:20px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5);z-index:1}
.human-panel{width:400px;background:linear-gradient(180deg,#667eea,#764ba2);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden}
.avatar-area{position:relative;z-index:2;text-align:center}
.name-display{color:white;font-size:20px;font-weight:bold;margin-top:10px}
.name-display .role{font-size:11px;opacity:.8;display:block}
.chat-panel{flex:1;display:flex;flex-direction:column;background:#fafbfc}
.chat-header{position:relative;padding:16px;text-align:center;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:17px;font-weight:bold}
.chat-header .sub{font-size:10px;opacity:.8;margin-top:2px}
.btn-clear{position:absolute;right:12px;top:14px;background:rgba(255,255,255,.2);border:none;color:white;padding:4px 12px;border-radius:10px;cursor:pointer;font-size:11px}
.trending-bar{padding:8px 12px;background:#f0f4ff;border-bottom:1px solid #d0d5fa;overflow-x:auto;white-space:nowrap;display:flex;align-items:center;gap:8px}
.trending-item{display:inline-block;background:#eef2ff;color:#333;font-size:12px;padding:4px 12px;border-radius:14px;cursor:pointer;border:1px solid #d0d5fa;flex-shrink:0;transition:.2s}
.trending-item:hover{background:#667eea;color:white;border-color:#667eea}
.messages{flex:1;overflow-y:auto;padding:15px;display:flex;flex-direction:column;gap:8px;background:#f5f7fa}
.msg{max-width:80%;padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.5;animation:in .3s}
@keyframes in{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg.user{align-self:flex-end;background:linear-gradient(135deg,#667eea,#764ba2);color:white}
.msg.bot{align-self:flex-start;background:white;color:#333;border:1px solid#e8e8e8;box-shadow:0 2px 8px rgba(0,0,0,.04)}
.input-area{display:flex;gap:10px;padding:12px 15px;background:white;border-top:1px solid#eee;align-items:center}
.input-area input{flex:1;padding:11px 16px;border-radius:22px;border:1.5px solid#e0e0e0;font-size:14px;outline:none;background:#f8f9fb}
.input-area input:focus{border-color:#667eea;box-shadow:0 0 0 3px rgba(102,126,234,.1)}
.btn-voice{width:42px;height:42px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;padding:0;background:#f0f0f5}
.btn-voice svg{width:20px;height:20px;fill:#555}
.btn-voice.recording{background:#ff4757}
.btn-voice.recording svg{fill:white}
.btn-send{width:42px;height:42px;border-radius:50%;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-size:18px;cursor:pointer;font-weight:bold;display:flex;align-items:center;justify-content:center}
.btn-send:hover{transform:scale(1.1);box-shadow:0 4px 15px rgba(102,126,234,.4)}
.voice-text{font-size:11px;color:#999;padding:2px 15px;text-align:center;min-height:16px}
#feedbackBar{display:none;padding:8px 15px;background:#f0f4ff;border-top:1px solid #d0d5fa;text-align:center;font-size:14px}
.avatar-selector{position:relative;display:inline-block}
.avatar-list{display:none;position:absolute;top:35px;left:50%;transform:translateX(-50%);background:rgba(30,30,40,0.95);border-radius:8px;padding:8px;min-width:120px;z-index:20;text-align:left}
.avatar-list div{padding:6px 10px;cursor:pointer;color:white;border-bottom:1px solid #333}
.avatar-list div:hover{background:rgba(102,126,234,0.4)}

/* 形象选择模态框 */
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:100;backdrop-filter:blur(5px)}
.modal-content{background:linear-gradient(135deg,#2d3a6e,#4a2c6e);border-radius:20px;padding:30px;text-align:center;color:white;max-width:500px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.5)}
.modal-content h2{margin-bottom:15px;font-size:24px}
.modal-options{display:flex;justify-content:center;gap:20px;margin-top:25px;flex-wrap:wrap}
.option-card{background:rgba(255,255,255,0.15);border-radius:15px;padding:20px;width:140px;cursor:pointer;transition:0.2s;border:2px solid transparent}
.option-card:hover{background:rgba(255,255,255,0.25);border-color:#FFD700;transform:translateY(-3px)}
.option-card img{width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:10px}
.option-card .label{font-size:14px;font-weight:bold}

</style>
</head>
<body>

<!-- 形象选择模态框 -->
<div class="modal-overlay" id="avatarModal">
    <div class="modal-content">
        <h2>选择您的AI导游形象</h2>
        <div class="modal-options">
            <div class="option-card" onclick="useDefault()">
                <img src="data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'%3E%3Ccircle cx=\'50\' cy=\'50\' r=\'40\' fill=\'%23FFE4C4\'/%3E%3Ccircle cx=\'35\' cy=\'45\' r=\'5\' fill=\'%231a1a2e\'/%3E%3Ccircle cx=\'65\' cy=\'45\' r=\'5\' fill=\'%231a1a2e\'/%3E%3Cpath d=\'M40 60 Q50 70 60 60\' stroke=\'%23d4786a\' stroke-width=\'3\' fill=\'none\'/%3E%3C/svg%3E" alt="默认形象">
                <div class="label">默认导游小灵</div>
            </div>
            <div class="option-card" id="uploadCard">
                <label for="avatarFile" style="display:block;cursor:pointer">
                    <div style="font-size:40px;margin-bottom:10px">+</div>
                    <div class="label">导入本地形象</div>
                </label>
                <input type="file" id="avatarFile" accept="image/*" style="display:none" onchange="uploadAndEnter(this)">
                <img id="previewImg" style="max-width:120px;max-height:120px;border-radius:15px;margin:10px auto;display:none">
            </div>
            <div class="option-card" onclick="quickStart()">
                <div style="font-size:40px;margin-bottom:10px">></div>
                <div class="label">快速进入</div>
            </div>
        </div>
        <div style="margin-top:20px;font-size:12px;opacity:0.7">选择后可随时在左侧更换形象</div>
    </div>
</div>

<div class="stars" id="stars"></div>
<div class="app">
<div class="human-panel">
<div class="avatar-area" id="avatarContainer">
<!-- 默认 SVG 数字人 -->
<svg id="avatarSvg" width="220" height="310" viewBox="0 0 220 320">
  <defs><radialGradient id="gg" cx="50%" cy="40%"><stop offset="0%" stop-color="#ffd700" stop-opacity="0.2"/><stop offset="100%" stop-color="#667eea" stop-opacity="0"/></radialGradient></defs>
  <circle cx="110" cy="120" r="100" fill="url(#gg)"/>
  <g id="bodyGroup">
    <rect x="65" y="195" width="90" height="80" rx="20" fill="#667eea"/>
    <ellipse cx="110" cy="270" rx="55" ry="45" fill="#667eea"/>
    <path d="M110 190 L100 210 L110 235 L120 210 Z" fill="#FFD700"/>
    <rect x="80" y="222" width="60" height="16" rx="4" fill="#FFD700"/>
    <text x="110" y="234" text-anchor="middle" font-size="8" fill="#4a3728" font-weight="bold">导游·小灵</text>
  </g>
  <g id="leftHand"><circle cx="52" cy="230" r="18" fill="#FFE4C4"/></g>
  <g id="rightHand"><circle cx="168" cy="230" r="18" fill="#FFE4C4"/></g>
  <g id="headGroup">
    <circle cx="110" cy="110" r="72" fill="#FFE4C4"/>
    <ellipse cx="110" cy="55" rx="82" ry="48" fill="#4a3728"/>
    <path d="M38 60 Q52 98 72 78 Q88 108 100 72 Q115 102 130 78 Q148 98 182 60 Q170 28 110 22 Q50 28 38 60Z" fill="#4a3728"/>
    <path id="ahoge" d="M110 22 Q115 -8 132 -12" stroke="#4a3728" stroke-width="3" fill="none" stroke-linecap="round"/>
    <ellipse id="lBrow" cx="82" cy="88" rx="13" ry="4" fill="#5a4030"/>
    <ellipse id="rBrow" cx="138" cy="88" rx="13" ry="4" fill="#5a4030"/>
    <ellipse cx="83" cy="104" rx="15" ry="18" fill="white"/>
    <circle id="lPupil" cx="86" cy="105" r="9" fill="#1a1a2e"/>
    <circle cx="90" cy="99" r="4.5" fill="white"/>
    <circle cx="82" cy="109" r="2" fill="white"/>
    <ellipse cx="137" cy="104" rx="15" ry="18" fill="white"/>
    <circle id="rPupil" cx="140" cy="105" r="9" fill="#1a1a2e"/>
    <circle cx="144" cy="99" r="4.5" fill="white"/>
    <circle cx="136" cy="109" r="2" fill="white"/>
    <ellipse cx="110" cy="125" rx="6" ry="5" fill="#F0C8A0"/>
    <path id="svgMouth" d="M100 142 Q110 150 120 142" stroke="#d4786a" stroke-width="2.5" fill="#e8908a" stroke-linecap="round"/>
    <ellipse id="lBlush" cx="65" cy="118" rx="13" ry="7" fill="#FFB0B0" opacity=".3"/>
    <ellipse id="rBlush" cx="155" cy="118" rx="13" ry="7" fill="#FFB0B0" opacity=".3"/>
    <path d="M58 88 Q40 93 42 118 Q44 142 58 148" stroke="#333" stroke-width="3" fill="none"/>
    <rect x="37" y="98" width="7" height="18" rx="3" fill="#333"/>
    <circle cx="40" cy="90" r="3" fill="#00ff88"/>
  </g>
</svg>
<div class="name-display"><span style="color:#00ff88">●</span> 小灵<div class="role">AI 智慧导游</div></div>
</div>
<div class="avatar-selector" style="margin-top:10px;">
    <button id="changeAvatarBtn" style="background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.3);color:white;padding:4px 12px;border-radius:12px;cursor:pointer;font-size:12px;">更换形象</button>
    <div id="avatarList" class="avatar-list"></div>
</div>
</div>
<div class="chat-panel">
<div class="chat-header">灵 山 胜 境<div class="sub">—— 千年佛国 · 智慧之旅 ——</div><button class="btn-clear" onclick="clearChat()">新对话</button></div>
<div class="trending-bar" id="trendingBar"><span style="font-size:12px;color:#667eea;font-weight:bold;">热门问题</span></div>
<div class="messages" id="messages"><div class="msg bot">嗨！我是小灵，你的专属AI导游~<br>灵山胜境的故事，让我讲给你听！</div></div>
<div class="voice-text" id="voiceText"></div>
<div id="feedbackBar">
    <span>本次导游服务怎么样？</span>
    <button onclick="sendFeedback('good')" style="background:#4caf50;color:white;border:none;padding:5px 15px;border-radius:15px;cursor:pointer;margin:0 5px;">满意</button>
    <button onclick="sendFeedback('neutral')" style="background:#ff9800;color:white;border:none;padding:5px 15px;border-radius:15px;cursor:pointer;margin:0 5px;">一般</button>
    <button onclick="sendFeedback('bad')" style="background:#f44336;color:white;border:none;padding:5px 15px;border-radius:15px;cursor:pointer;margin:0 5px;">不满意</button>
</div>
<div class="input-area">
<input type="text" id="userInput" placeholder="问我任何问题，或按住右侧麦克风说话" onkeypress="if(event.key=='Enter')sendText()">
<button class="btn-voice" id="voiceBtn" title="按住说话">
  <svg viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
</button>
<button class="btn-send" onclick="sendText()" title="发送">
  <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
</button>
</div></div></div>
<script>
// 背景星星
for(let i=0;i<60;i++){const s=document.createElement('div');s.className='star';s.style.left=Math.random()*100+'%';s.style.top=Math.random()*100+'%';s.style.width=s.style.height=(1+Math.random()*3)+'px';s.style.animationDelay=Math.random()*2+'s';document.getElementById('stars').appendChild(s)}

// 动画元素
let headGroup=document.getElementById('headGroup'),lPupil=document.getElementById('lPupil'),rPupil=document.getElementById('rPupil'),lBlush=document.getElementById('lBlush'),rBlush=document.getElementById('rBlush'),svgMouth=document.getElementById('svgMouth'),rightHand=document.getElementById('rightHand'),ahoge=document.getElementById('ahoge');
let mouthTimer, currentAudio=null, currentAvatarType='svg';

function startSpeak(){if(currentAvatarType!=='svg'||!svgMouth)return;let o=true;mouthTimer=setInterval(()=>{svgMouth.setAttribute('d',o?'M97 140 Q110 154 123 140':'M100 142 Q110 148 120 142');o=!o},120)}
function stopSpeak(){clearInterval(mouthTimer);if(svgMouth)svgMouth.setAttribute('d','M100 142 Q110 150 120 142')}
function tilt(d){if(headGroup){headGroup.style.transform='rotate('+d+'deg)';headGroup.style.transformOrigin='110px 110px'}}
function resetHead(){if(headGroup)headGroup.style.transform='rotate(0deg)'}
function look(d){const o=d==='l'?-4:4;if(lPupil)lPupil.setAttribute('cx',86+o);if(rPupil)rPupil.setAttribute('cx',140+o)}
function resetEyes(){if(lPupil)lPupil.setAttribute('cx',86);if(rPupil)rPupil.setAttribute('cx',140)}
function happy(){if(lBlush)lBlush.setAttribute('opacity','.6');if(rBlush)rBlush.setAttribute('opacity','.6');setTimeout(()=>{if(lBlush)lBlush.setAttribute('opacity','.3');if(rBlush)rBlush.setAttribute('opacity','.3')},1500)}
function wave(){let p=0;const t=setInterval(()=>{if(rightHand){rightHand.style.transform='rotate('+(p%2?-20:10)+'deg)';rightHand.style.transformOrigin='168px 230px'}p++;if(p>6){clearInterval(t);if(rightHand)rightHand.style.transform='rotate(0deg)'}},200)}
function speakAnim(){startSpeak();tilt(-3);look('l');setTimeout(()=>{tilt(3);look('r')},800);setTimeout(()=>{tilt(-2);look('l')},1600);setTimeout(()=>{resetHead();resetEyes()},2400)}
function stopAll(){if(currentAudio){currentAudio.pause();currentAudio=null}stopSpeak();resetHead();resetEyes();document.getElementById('voiceText').textContent=''}

function addMsg(t,u){const d=document.createElement('div');d.className='msg '+(u?'user':'bot');d.textContent=t;document.getElementById('messages').appendChild(d);document.getElementById('messages').scrollTop=document.getElementById('messages').scrollHeight}

// 文字发送
async function sendText(){
  const i=document.getElementById('userInput'),b=document.querySelector('.btn-send');
  const t=i.value.trim();if(!t)return;
  addMsg(t,true);i.value='';b.style.opacity='.5';
  try{
    const r=await fetch('/api/chat/tts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:t})});
    const d=await r.json();
    addMsg(d.answer,false);
    showFeedback();
    if(d.audio_url){
      document.getElementById('voiceText').textContent='播放中...';
      stopAll();const a=new Audio(d.audio_url);currentAudio=a;
      a.onplay=()=>{speakAnim();if(ahoge)ahoge.setAttribute('d','M110 22 Q118 -10 135 -14');setTimeout(()=>{if(ahoge)ahoge.setAttribute('d','M110 22 Q115 -8 132 -12')},400)};
      a.onended=()=>{stopSpeak();resetHead();resetEyes();happy();document.getElementById('voiceText').textContent='';currentAudio=null};
      a.play();
    }else{happy()}
  }catch(e){addMsg('网络波动，请稍后重试',false)}
  b.style.opacity='1';i.focus();
}

async function clearChat(){
  stopAll();
  try{await fetch('/api/chat/clear',{method:'POST'})}catch(e){}
  document.getElementById('messages').innerHTML='<div class="msg bot">对话已重置~<br>我是小灵，有什么想问的？</div>';
}

document.addEventListener('keydown',function(e){if(currentAudio){e.preventDefault();stopAll();document.getElementById('voiceText').textContent='已停止朗读'}});

// 语音录制
let mr,chunks=[],recording=false;
async function startRec(){
  try{
    const s=await navigator.mediaDevices.getUserMedia({audio:true});
    mr=new MediaRecorder(s,{mimeType:'audio/webm'});chunks=[];
    mr.ondataavailable=e=>chunks.push(e.data);
    mr.onstop=async()=>{
      s.getTracks().forEach(t=>t.stop());
      const f=new FormData();f.append('file',new Blob(chunks,{type:'audio/webm'}),'r.webm');
      try{
        const r=await fetch('/api/chat/voice',{method:'POST',body:f});
        const d=await r.json();
        document.getElementById('voiceText').textContent='你说：'+d.user_text;
        addMsg(d.reply_text,false);
        showFeedback();
        if(d.audio_url){
          stopAll();const a=new Audio(d.audio_url);currentAudio=a;
          a.onplay=()=>{speakAnim();if(ahoge)ahoge.setAttribute('d','M110 22 Q118 -10 135 -14');setTimeout(()=>{if(ahoge)ahoge.setAttribute('d','M110 22 Q115 -8 132 -12')},400)};
          a.onended=()=>{stopSpeak();resetHead();resetEyes();happy();document.getElementById('voiceText').textContent='';currentAudio=null};
          a.play();
        }else{happy()}
      }catch(e){stopSpeak()}
    };
    mr.start();recording=true;
    document.getElementById('voiceBtn').classList.add('recording');
    document.getElementById('voiceText').textContent='聆听中...';
  }catch(e){document.getElementById('voiceText').textContent='请允许麦克风权限'}
}
function stopRec(){
  if(mr&&recording){mr.stop();recording=false}
  document.getElementById('voiceBtn').classList.remove('recording');
  document.getElementById('voiceText').textContent='识别中...';
}
document.getElementById('voiceBtn').addEventListener('mousedown',startRec);
document.getElementById('voiceBtn').addEventListener('mouseup',stopRec);
document.getElementById('voiceBtn').addEventListener('mouseleave',()=>{if(recording)stopRec()});
document.getElementById('voiceBtn').addEventListener('touchstart',e=>{e.preventDefault();startRec()});
document.getElementById('voiceBtn').addEventListener('touchend',stopRec);

function showFeedback(){document.getElementById('feedbackBar').style.display='block'}
function hideFeedback(){document.getElementById('feedbackBar').style.display='none'}
async function sendFeedback(rating){
  try{await fetch('/api/feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({rating})});}catch(e){}
  hideFeedback();
  document.getElementById('voiceText').textContent='感谢您的反馈！';
  setTimeout(()=>{document.getElementById('voiceText').textContent=''},2000);
}
const origAddMsg = addMsg;
addMsg = function(text, isUser) { origAddMsg(text, isUser); if(!isUser) showFeedback(); };

// 热门问题
async function loadTrending(){
  try{
    const res=await fetch('/api/admin/dashboard');
    const data=await res.json();
    const bar=document.getElementById('trendingBar');
    bar.querySelectorAll('.trending-item').forEach(el=>el.remove());
    if(data.top_questions && data.top_questions.length>0){
      data.top_questions.forEach(item=>{
        const tag=document.createElement('span');
        tag.className='trending-item';
        tag.textContent=item.q;
        tag.onclick=()=>{document.getElementById('userInput').value=item.q;sendText();};
        bar.appendChild(tag);
      });
    }
  }catch(e){}
}
loadTrending();
setInterval(loadTrending, 30000);

// 数字人切换
async function loadAvatars(){
  const list=document.getElementById('avatarList');
  try{
    const res=await fetch('/api/admin/avatars');
    const avatars=await res.json();
    list.innerHTML='';
    avatars.forEach(av=>{
      const item=document.createElement('div');
      item.textContent=av.name;
      item.onclick=()=>switchAvatar(av);
      list.appendChild(item);
    });
  }catch(e){list.innerHTML='<div>加载失败</div>'}
}
function switchAvatar(avatar){
  const container=document.getElementById('avatarContainer');
  if(avatar.type==='svg'||avatar.id==='default'){
    container.innerHTML=`<svg id="avatarSvg" width="220" height="310" viewBox="0 0 220 320">
      <defs><radialGradient id="gg" cx="50%" cy="40%"><stop offset="0%" stop-color="#ffd700" stop-opacity="0.2"/><stop offset="100%" stop-color="#667eea" stop-opacity="0"/></radialGradient></defs>
      <circle cx="110" cy="120" r="100" fill="url(#gg)"/>
      <g id="bodyGroup"><rect x="65" y="195" width="90" height="80" rx="20" fill="#667eea"/><ellipse cx="110" cy="270" rx="55" ry="45" fill="#667eea"/><path d="M110 190 L100 210 L110 235 L120 210 Z" fill="#FFD700"/><rect x="80" y="222" width="60" height="16" rx="4" fill="#FFD700"/><text x="110" y="234" text-anchor="middle" font-size="8" fill="#4a3728" font-weight="bold">导游·小灵</text></g>
      <g id="leftHand"><circle cx="52" cy="230" r="18" fill="#FFE4C4"/></g>
      <g id="rightHand"><circle cx="168" cy="230" r="18" fill="#FFE4C4"/></g>
      <g id="headGroup">
        <circle cx="110" cy="110" r="72" fill="#FFE4C4"/><ellipse cx="110" cy="55" rx="82" ry="48" fill="#4a3728"/>
        <path d="M38 60 Q52 98 72 78 Q88 108 100 72 Q115 102 130 78 Q148 98 182 60 Q170 28 110 22 Q50 28 38 60Z" fill="#4a3728"/>
        <path id="ahoge" d="M110 22 Q115 -8 132 -12" stroke="#4a3728" stroke-width="3" fill="none" stroke-linecap="round"/>
        <ellipse id="lBrow" cx="82" cy="88" rx="13" ry="4" fill="#5a4030"/><ellipse id="rBrow" cx="138" cy="88" rx="13" ry="4" fill="#5a4030"/>
        <ellipse cx="83" cy="104" rx="15" ry="18" fill="white"/><circle id="lPupil" cx="86" cy="105" r="9" fill="#1a1a2e"/><circle cx="90" cy="99" r="4.5" fill="white"/><circle cx="82" cy="109" r="2" fill="white"/>
        <ellipse cx="137" cy="104" rx="15" ry="18" fill="white"/><circle id="rPupil" cx="140" cy="105" r="9" fill="#1a1a2e"/><circle cx="144" cy="99" r="4.5" fill="white"/><circle cx="136" cy="109" r="2" fill="white"/>
        <ellipse cx="110" cy="125" rx="6" ry="5" fill="#F0C8A0"/>
        <path id="svgMouth" d="M100 142 Q110 150 120 142" stroke="#d4786a" stroke-width="2.5" fill="#e8908a" stroke-linecap="round"/>
        <ellipse id="lBlush" cx="65" cy="118" rx="13" ry="7" fill="#FFB0B0" opacity=".3"/><ellipse id="rBlush" cx="155" cy="118" rx="13" ry="7" fill="#FFB0B0" opacity=".3"/>
        <path d="M58 88 Q40 93 42 118 Q44 142 58 148" stroke="#333" stroke-width="3" fill="none"/><rect x="37" y="98" width="7" height="18" rx="3" fill="#333"/><circle cx="40" cy="90" r="3" fill="#00ff88"/>
      </g>
    </svg>`;
    currentAvatarType='svg';
    setTimeout(()=>{
      headGroup=document.getElementById('headGroup');lPupil=document.getElementById('lPupil');rPupil=document.getElementById('rPupil');
      lBlush=document.getElementById('lBlush');rBlush=document.getElementById('rBlush');svgMouth=document.getElementById('svgMouth');
      rightHand=document.getElementById('rightHand');ahoge=document.getElementById('ahoge');
    },100);
  } else {
    container.innerHTML=`<img src="${avatar.url}" alt="${avatar.name}" style="max-width:200px;max-height:300px;border-radius:20px;box-shadow:0 4px 15px rgba(0,0,0,.3);"/>`;
    currentAvatarType='image';
    headGroup=null;svgMouth=null;
  }
  document.getElementById('avatarList').style.display='none';
}
document.getElementById('changeAvatarBtn').addEventListener('click',()=>{
  const list=document.getElementById('avatarList');
  list.style.display=list.style.display==='none'?'block':'none';
  loadAvatars();
});
document.addEventListener('click',function(e){
  const list=document.getElementById('avatarList'),btn=document.getElementById('changeAvatarBtn');
  if(list&&btn&&!list.contains(e.target)&&e.target!==btn)list.style.display='none';
});


// 形象选择逻辑
function showMainApp(){
  document.getElementById('avatarModal').style.display='none';
  document.getElementById('mainApp').style.display='flex';
}
function useDefault(){
  if(typeof switchAvatar==='function') switchAvatar({type:'svg',id:'default'});
  showMainApp();
}
function quickStart(){
  showMainApp();
}
function uploadAndEnter(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    const preview = document.getElementById('previewImg');
    preview.src = e.target.result;
    preview.style.display = 'block';
    const form = new FormData();
    form.append('file', file);
    fetch('/api/admin/upload-avatar', {method:'POST', body:form})
      .then(r=>r.json())
      .then(data=>{
        if(data.url){
          if(typeof switchAvatar==='function') switchAvatar({type:'image', url:data.url, name:file.name});
          showMainApp();
        } else {
          alert('上传失败：'+data.error);
        }
      })
      .catch(()=>alert('网络错误'));
  };
  reader.readAsDataURL(file);
}
// 初始显示模态框，隐藏主界面
document.addEventListener('DOMContentLoaded', function(){
  // 给主界面加一个 id 以便控制显示
  const app = document.querySelector('.app');
  if(app) app.id = 'mainApp';
  // 默认显示模态框
  const modal = document.getElementById('avatarModal');
  if(modal) modal.style.display = 'flex';
  if(app) app.style.display = 'none';
});

setTimeout(wave,500);
</script>
</body></html>
